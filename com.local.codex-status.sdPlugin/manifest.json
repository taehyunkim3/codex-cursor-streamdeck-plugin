{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Icon": "imgs/action",
      "Name": "Agent Session",
      "PropertyInspectorPath": "ui/thread-status.html",
      "States": [
        {
          "Image": "imgs/key-default",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Show a Codex or Cursor agent session status on this key.",
      "UUID": "com.local.codex-status.session",
      "UserTitleEnabled": false
    },
    {
      "Icon": "imgs/action",
      "Name": "Codex Tokens",
      "States": [
        {
          "Image": "imgs/key-default",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Show Codex token and rate-limit remaining status.",
      "UUID": "com.local.codex-status.tokens",
      "UserTitleEnabled": false
    }
  ],
  "Author": "Local",
  "Category": "Agents",
  "CategoryIcon": "imgs/action",
  "CodePath": "bin/plugin.js",
  "Description": "Shows local Codex and Cursor agent activity on Stream Deck keys.",
  "Icon": "imgs/plugin",
  "Name": "Agent Status",
  "Nodejs": {
    "Version": "24"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "13"
    }
  ],
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "UUID": "com.local.codex-status",
  "Version": "0.1.0.0"
}
